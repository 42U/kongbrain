{
  "name": "kongbrain",
  "version": "0.3.12",
  "description": "Graph-backed persistent memory engine for OpenClaw. Replaces the default context window with SurrealDB + vector embeddings that learn across sessions.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/42U/kongbrain.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-engine",
    "memory",
    "persistent-memory",
    "graph-database",
    "surrealdb",
    "vector-search",
    "embeddings",
    "bge-m3",
    "ai-agent",
    "cognitive-architecture",
    "knowledge-graph",
    "llm"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.3.23"
    },
    "compat": {
      "pluginApi": ">=2026.3.23",
      "minGatewayVersion": "2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.3.23",
      "pluginSdkVersion": "2026.3.23"
    }
  },
  "scripts": {
    "prepack": "cp README.md README.github.md && cp README.npm.md README.md",
    "postpack": "cp README.github.md README.md && rm README.github.md",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "node-llama-cpp": "^3.18.1",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": ">=1.0.0",
    "@mariozechner/pi-ai": ">=1.0.0",
    "openclaw": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-agent-core": {
      "optional": true
    }
  }
}
